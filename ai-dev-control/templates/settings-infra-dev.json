{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Infrastructure Dev project-level settings. Place at .claude/settings.json in the project repo. Extends baseline. Allows Turso sync and admin scripts. Blocks pipeline phase scripts.",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(./scripts/admin/sync_turso_schema.sh)",
      "Bash(python3 scripts/admin/apply_migrations.py *)",
      "Bash(turso auth token *)",
      "Bash(turso db shell * --location *)",
      "Bash(turso db list *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)"
    ],
    "ask": [
      "Bash(turso db destroy *)",
      "Bash(turso db execute *)",
      "Bash(git push *)",
      "Bash(rm *)"
    ],
    "deny": [
      "Bash(./scripts/run_5_phase_pipeline.sh *)",
      "Bash(python3 scripts/infrastructure/phase* *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
